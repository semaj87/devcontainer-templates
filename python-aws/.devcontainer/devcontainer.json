{
  "name": "Python AWS",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/aws-cli:1": {},
    "ghcr.io/devcontainers/features/terraform:1": {},
  },
  "postCreateCommand": "pip install poetry && [ -f pyproject.toml ] && poetry install || true",
  "containerEnv": {
    "SHELL": "/bin/zsh"
  },
  "mounts": [
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,readonly"
  ],
  "remoteUser": "root",
  "customizations": {
    "jetbrains": {
      "backend": "PyCharm"
    }
  }
}
