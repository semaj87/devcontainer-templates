{
  "name": "Kubernetes",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "containerEnv": {
    "SHELL": "/bin/zsh"
  },
  "mounts": [
    "source=${localEnv:HOME}/.kube,target=/root/.kube,type=bind",
    "source=${localEnv:HOME}/.aws,target=/root/.aws,type=bind,readonly"
  ],
  "customizations": {
    "jetbrains": {
      "backend": "PyCharm"
    }
  }
}
